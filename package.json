{
    "name": "natours",
    "version": "1.0.0",
    "description": "Natours - Full-Stack Tour Booking Application",
    "private": true,
    "scripts": {
        "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
