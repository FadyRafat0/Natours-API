"column":6}},{"generated":{"line":60,"column":0},"source":"mapbox.js","original":{"line":46,"column":0}},{"generated":{"line":60,"column":1},"source":"mapbox.js","original":{"line":46,"column":1}},{"generated":{"line":61,"column":0},"source":"mapbox.js","original":{"line":46,"column":2},"name":"exports"},{"generated":{"line":61,"column":7},"source":"mapbox.js","original":{"line":46,"column":2}},{"generated":{"line":61,"column":8},"source":"mapbox.js","original":{"line":46,"column":2},"name":"displayMap"},{"generated":{"line":61,"column":18},"source":"mapbox.js","original":{"line":46,"column":2}},{"generated":{"line":61,"column":21},"source":"mapbox.js","original":{"line":46,"column":2},"name":"displayMap"},{"generated":{"line":61,"column":31},"source":"mapbox.js","original":{"line":46,"column":2}}],"sources":{"mapbox.js":"/* eslint-disable */\r\n\r\nexport const displayMap = (locations) => {\r\n    // 1. Initialize the map container without a fixed view\r\n    const map = L.map('map', { scrollWheelZoom: false });\r\n\r\n    // 2. Add the free OpenStreetMap tile layer (No API keys or cards required!)\r\n    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {\r\n        attribution:\r\n            '&copy; <a href=\"https://www.openstreetmap.org/copyright\">OpenStreetMap</a> contributors',\r\n    }).addTo(map);\r\n\r\n    // Array to collect all coordinates for auto-fitting the camera bounds\r\n    const points = [];\r\n\r\n    // 3. Loop through locations to add markers and popups\r\n    locations.forEach((loc) => {\r\n        // Flip coordinates: Leaflet strictly expects [latitude, longitude]\r\n        const [lng, lat] = loc.coordinates;\r\n        const currentPoint = [lat, lng];\r\n\r\n        points.push(currentPoint);\r\n\r\n        // Create a custom icon utilizing Jonas's existing CSS '.marker' class\r\n        const customIcon = L.divIcon({\r\n            className: 'marker',\r\n            iconSize: [30, 30],\r\n            iconAnchor: [15, 30], // Anchors the bottom-middle of the pin to the map coordinate\r\n            popupAnchor: [0, -30], // Positions the popup cleanly right above the pin\r\n        });\r\n\r\n        // 4. Add the marker with the custom green icon, attach the popup, and open it\r\n        L.marker(currentPoint, { icon: customIcon })\r\n            .addTo(map)\r\n            .bindPopup(`<p>Day ${loc.day}: ${loc.description}</p>`, {\r\n                autoClose: false,\r\n                className: 'leaflet-popup', // Inherits Jonas's clean popup text styling\r\n            })\r\n            .openPopup();\r\n    });\r\n\r\n    // 5. Automatically adjust the map zoom/position to fit all tour stops perfectly\r\n    map.fitBounds(points, {\r\n        padding: [100, 100], // Adds a comfortable pixel buffer around the edges of your map canvas\r\n    });\r\n};\r\n"},"lineCount":null}},"error":null,"hash":"fc333998016058ab9d6e05851de304fb","cacheData":{"env":{}}}