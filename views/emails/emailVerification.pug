extends baseEmail

block content
  p Hi #{firstName},
  p To verify your email, please click the button below and then enter the one-time passcode from this email on the verification page.
  table.btn.btn-primary(role='presentation', border='0', cellpadding='0', cellspacing='0')
    tbody
      tr
        td(align='left')
          table(role='presentation', border='0', cellpadding='0', cellspacing='0')
            tbody
              tr
                td
                  a(href=`${url}`, target='_blank') Verify your email
  // OTP block (receives `otp` variable)
  table(role='presentation', border='0', cellpadding='0', cellspacing='0')
    tbody
      tr
        td
          .content-block.align-center
            p(style='font-size:13px;color:#666;line-height:1.4;margin-top:12px;margin-bottom:8px') Keep this one-time passcode handy — you'll enter it on the verification page:
            // OTP box
            table(role='presentation', border='0', cellpadding='0', cellspacing='0', align='center')
              tbody
                tr
                  td(style='background:#f6f6f6;border-radius:8px;padding:14px 22px;text-align:center')
                    p(style='margin:0;font-size:12px;color:#999;text-transform:uppercase;letter-spacing:1px') OTP
                    p(style='margin:6px 0 0;font-size:22px;font-weight:700;color:#333;letter-spacing:4px') #{otp}
  p If you need any help with booking your next tour, please don't hesitate to contact me!
  p - Fady Rafat, CEO